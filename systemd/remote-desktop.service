[Unit]
Description=Remote Desktop Server (Wayland)
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/remote-desktop-server
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=%E/remote-desktop

# Environment
Environment=RUST_LOG=info

[Install]
WantedBy=default.target
